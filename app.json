{
  "expo": {
    "name": "KmerFoodLens",
    "slug": "kfl",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.techainova.kmerfoodlens"
    },
    "android": {
      "package": "com.techainova.kmerfoodlens"
    },
    "plugins": [
      "expo-camera",
      "expo-location",
      "expo-font"
    ],
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": ["expo-av", "expo-modules-jsi"]
      }
    }
  }
}